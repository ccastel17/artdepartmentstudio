# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?appName=art-department-studio

# JWT Secret for authentication (generate a secure random string)
JWT_SECRET=your-secret-key-change-this-in-production

# Public API URL (will be your Vercel domain in production)
NEXT_PUBLIC_API_URL=https://your-domain.vercel.app
